# App
PROJECT_NAME="FastAPI Template"
VERSION="0.1.0"
DEBUG=true

# Database — postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/dbname"

# Redis
REDIS_URL="redis://localhost:6379/0"

# CORS — JSON list of allowed origins in production
# ALLOWED_ORIGINS=["https://myapp.com","https://www.myapp.com"]
ALLOWED_ORIGINS=[]

# Security — generate with: openssl rand -hex 32
SECRET_KEY="change-me-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Auth — skips JWT verification entirely (every request is "authenticated").
# MUST be false whenever DEBUG=false — enforced at startup, app will refuse to boot otherwise.
BYPASS_AUTH=true
